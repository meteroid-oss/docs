{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Meteroid Documentation",
  "icons": {
    "library": "tabler"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "colors": {
    "primary": "#000000",
    
    "light": "#ffffff",
    "dark": "#000000"

  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "home",
              "introduction/understanding-meteroid",
              "introduction/get-started-with-meteroid",
              "introduction/glossary"
            ]
          },
          {
            "group": "Metering",
            "pages": [
              "metering/billable-metrics",
              "metering/managing-events"
            ]
          },
          {
            "group": "Quotes",
            "pages": [
              "quotes/introduction",
              "quotes/create-and-manage-quotes"
            ]
          },
          {
            "group": "Billing",
            "pages": [
              "billing/managing-plans",
              "billing/creating-products-and-modeling-your-pricing",
              "billing/managing-trials-and-coupons",
              "billing/managing-add-ons", 
              "billing/managing-upgrade-&-downgrade-and-price-updates"
            ]
          },
          {
            "group": "Subscriptions",
            "pages": [
              "subscriptions/what-is-a-subscription",
              "subscriptions/creating-a-subscription",
              "subscriptions/managing-a-subscription",
              "subscriptions/updating-a-subscription",
              "subscriptions/check-out"
            ]
          },
          {
            "group": "Customer",
            "pages": [
              "customer/managing-customers",
              "customer/customer-portal"
            ]
          },
          {
            "group": "Invoices",
            "pages": [
              "invoices/managing-invoices"
            ]
          },
          {
            "group": "Credit Notes",
            "pages": [
              "credit-notes/create-and-manage-credit-notes"
            ]
          },
          {
            "group": "Settings",
            "pages": [
              "settings/merchant",
              "settings/taxes",
              "settings/invoices-settings",
              "settings/tenants",
              "settings/payment-methods"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/general-information",
              "integrations/hubspot",
              "integrations/pennylane"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "https://api.meteroid.com/api-docs/openapi.json",
                    "collapsed": true
        
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Changelog",
            "pages": [
              "changelog/product-update"
            ]
          }
        ]
      }
    ],
    "global": {
    "anchors": [
      {
        "anchor": "Blog",
        "href": "https://meteroid.com/blog",
        "icon": "book"

      },
      {
        "anchor": "Talk to us",
        "href": "https://meteroid.com/talk-to-us",
        "icon": "message"
      },

      {
        "anchor": "GitHub",
        "href": "https://go.meteroid.com/github",
        "icon": "github"

      }
    ]
  }
},
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://meteroid.com"
  },
  "background": {
    "color": {
      "light": "#f7f7f7",
      "dark": "#111111"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Talk to us",
        "href": "https://meteroid.com/talk-to-us"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "https://app.meteroid.com/registration"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/meteroid-oss/meteroid",
      "linkedin": "https://www.linkedin.com/company/meteroid",
      "discord": "https://go.meteroid.com/discord"
    }
  },
  "integrations": {
    "telemetry": {
      "enabled": false
    }
  },
 "contextual": {
   "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "grok",
     "mcp",
     "cursor",
     "vscode"
   ]
 }
}